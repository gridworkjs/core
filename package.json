{
  "name": "@gridworkjs/core",
  "version": "1.1.1",
  "description": "geometry primitives and spatial index protocol",
  "type": "module",
  "main": "index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./index.js"
    },
    "./geometry": {
      "types": "./types/src/geometry.d.ts",
      "default": "./src/geometry.js"
    },
    "./bounds": {
      "types": "./types/src/bounds.d.ts",
      "default": "./src/bounds.js"
    },
    "./protocol": {
      "types": "./types/src/protocol.d.ts",
      "default": "./src/protocol.js"
    }
  },
  "scripts": {
    "test": "node --test",
    "prepublishOnly": "npx tsc --declaration --allowJs --emitDeclarationOnly --skipLibCheck --target es2020 --module nodenext --moduleResolution nodenext --strict false --esModuleInterop true --outDir ./types src/geometry.js src/bounds.js src/protocol.js index.js"
  },
  "keywords": [
    "spatial",
    "geometry",
    "quadtree",
    "rtree",
    "spatial-index",
    "bounds",
    "point",
    "rect",
    "circle"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gridworkjs/core.git"
  },
  "files": [
    "index.js",
    "src/",
    "types/"
  ],
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
